{
  "expo": {
    "name": "PreventVital",
    "slug": "PreventVital",
    "owner": "ajay-dev9",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/premium-icon.png",
    "scheme": "preventvital",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "entitlements": {
        "com.apple.developer.healthkit": true
      },
      "infoPlist": {
        "NSHealthShareUsageDescription": "We need access to your health data to track your daily activity vitals.",
        "NSHealthUpdateUsageDescription": "We need access to update your health data."
      },
      "bundleIdentifier": "com.preventvital.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.preventvital.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.BODY_SENSORS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/premium-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "barStyle": "dark-content",
        "backgroundColor": "#FFFFFF"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#3A8AB5",
          "dark": {
            "backgroundColor": "#3A8AB5"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/premium-icon.png",
          "color": "#51A6CB",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "18d8ec02-3133-4a8f-8e8d-d139b00b55d6"
      }
    }
  }
}
